# Development Environment Configuration Template
# DO NOT commit actual credentials to Git
# Copy this file to .env.local and add your actual development credentials

# Replace these with your actual development values:
VITE_SUPABASE_URL=your_development_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_development_anon_key_here

# DO NOT set SUPABASE_SERVICE_ROLE_KEY in client-side environment variables
# Service Role Key should only be used in secure server-side functions
